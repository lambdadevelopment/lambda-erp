# Copy to `.env` before running `docker compose up`.
# OpenAI is the default chat provider.
OPENAI_API_KEY=sk-your-key-here

# Optional: Anthropic is used as a code-specialist sub-agent for custom
# analytics reports. GPT stays as the orchestrator; when it decides to call
# `create_custom_analytics_report` or `update_custom_analytics_report` with
# a plain-language intent/feedback, the backend delegates the JS spec
# generation to ANTHROPIC_CODE_MODEL.
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_CODE_MODEL=claude-opus-4-7

# Optional: enable the hosted public-demo experience. When set to 1, the
# container creates a shared `public_manager` user and the chat-replay
# records so visitors can click "Enter Live Demo" without registering.
# Leave unset (or =0) for the default self-hosted flow where the first
# user to register on the login page becomes admin.
# LAMBDA_ERP_ENABLE_PUBLIC_DEMO=1

# Optional: pin a specific JWT signing secret. You normally don't need
# this — on first boot the backend auto-generates a secret and saves it
# to /data/.jwt_secret (next to the SQLite DB) so login cookies survive
# container restarts. Only set this if you're running multiple instances
# behind a load balancer and they all need to agree on the secret.
# JWT_SECRET_KEY=your-long-random-string
